{
  "manifest_version": 3,
  "name": "My YouTube Search",
  "version": "1.2",
  "description": "Press Shift+Y while watching to save video for keyword search",
  "permissions": [],
  "host_permissions": ["http://localhost:7799/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Search"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
